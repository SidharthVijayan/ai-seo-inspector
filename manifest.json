{
  "manifest_version": 3,
  "name": "AI SEO Inspector",
  "version": "1.1",
  "description": "AI SEO + Persuasion + Content Intelligence Tool",

  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
