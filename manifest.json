{
  "manifest_version": 3,
  "name": "AI SEO Quick Inspector",
  "version": "1.0",
  "description": "Quickly analyze on-page SEO elements.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI SEO Inspector"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}