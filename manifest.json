{
  "manifest_version": 3,
  "name": "AI SEO & LLM Visibility Inspector",
  "version": "2.0",
  "description": "SEO + AI Visibility + LLM Optimization Tool",

  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
